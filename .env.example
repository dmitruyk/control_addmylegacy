DEBUG=True
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,control.addmylegacy.com
# Required for HTTPS forms (Django 4+); include scheme and port where applicable
CSRF_TRUSTED_ORIGINS=https://control.addmylegacy.com,http://127.0.0.1:8000,http://localhost:8000

# Local dev: DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (set DATABASE_URL or individual DB_* vars)
# Synology QuickConnect example; on-container use DB_HOST=192.168.0.230
DB_HOST=192-168-0-230.example.direct.quickconnect.to
DB_PORT=5448
DB_NAME=control_addmylegacy
DB_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@192-168-0-230.example.direct.quickconnect.to:5448/control_addmylegacy

SITE_NAME=AddMyLegacy Control
SITE_URL=https://control.addmylegacy.com
MAIN_SITE_URL=https://addmylegacy.com
TIME_ZONE=America/Los_Angeles

# Bump on each deploy to bust TV browser cache for static assets
STATIC_BUILD_ID=1

# Auto-refresh interval for the TV dashboard (seconds); 0 disables refresh
TV_REFRESH_SECONDS=60

# Poll /health/ while waiting for container to come back after deploy (seconds)
TV_HEALTH_POLL_SECONDS=3

# Set true before restarting the container to show /updating/ instead of the gallery
TV_MAINTENANCE_MODE=false

# Weather cache for Palo Alto + San Francisco (seconds, Open-Meteo)
TV_WEATHER_CACHE_SECONDS=600
TV_WEATHER_HOURLY_COUNT=6

# Google Analytics 4 measurement ID (set empty to disable tracking)
GOOGLE_ANALYTICS_ID=

# Gunicorn (Docker)
GUNICORN_TIMEOUT=120
GUNICORN_WORKERS=2

# Behind nginx/traefik terminating HTTPS
TRUST_PROXY_HEADERS=True
USE_HTTPS=True
